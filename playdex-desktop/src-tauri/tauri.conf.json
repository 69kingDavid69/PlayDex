{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "PlayDex",
  "version": "0.2.1",
  "identifier": "com.playdex.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "macOSPrivateApi": false,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "PlayDex",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Permite a la ventana principal usar IPC base y abrir selectores de archivos.",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "dialog:allow-open"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "category": "Music",
    "copyright": "",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/engine/**/*"]
  },
  "plugins": {}
}
